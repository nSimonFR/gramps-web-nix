{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "description": "Track gramps-web (frontend) releases in pkgs/frontend.nix",
      "customType": "regex",
      "managerFilePatterns": ["/^pkgs/frontend\\.nix$/"],
      "matchStrings": [
        "version\\s*=\\s*\"(?<currentValue>[^\"]+)\";"
      ],
      "depNameTemplate": "gramps-project/gramps-web",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "description": "Track gramps-web-api releases in pkgs/gramps-web-api/default.nix",
      "customType": "regex",
      "managerFilePatterns": ["/^pkgs/gramps-web-api/default\\.nix$/"],
      "matchStrings": [
        "version\\s*=\\s*\"(?<currentValue>[^\"]+)\";"
      ],
      "depNameTemplate": "gramps-project/gramps-web-api",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "description": "Group flake input updates",
      "matchManagers": ["nix"],
      "groupName": "flake inputs",
      "schedule": ["every weekend"]
    },
    {
      "description": "Upstream bumps — ci/renovate-update.sh recomputes src (+ frontend npmDepsHash) so each PR is build-ready",
      "matchDepNames": ["gramps-project/gramps-web", "gramps-project/gramps-web-api"],
      "automerge": false,
      "schedule": ["at any time"],
      "postUpgradeTasks": {
        "commands": ["bash ci/renovate-update.sh {{{depName}}} {{{newVersion}}}"],
        "executionMode": "branch",
        "fileFilters": ["**/*"]
      }
    }
  ]
}
