{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "description": "Track gramps-web (frontend) releases in pkgs/frontend.nix",
      "customType": "regex",
      "fileMatch": ["^pkgs/frontend\\.nix$"],
      "matchStrings": [
        "version\\s*=\\s*\"(?<currentValue>[^\"]+)\";"
      ],
      "depNameTemplate": "gramps-project/gramps-web",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "description": "Track gramps-web-api releases in pkgs/gramps-web-api/default.nix",
      "customType": "regex",
      "fileMatch": ["^pkgs/gramps-web-api/default\\.nix$"],
      "matchStrings": [
        "version\\s*=\\s*\"(?<currentValue>[^\"]+)\";"
      ],
      "depNameTemplate": "gramps-project/gramps-web-api",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "description": "Group flake input updates",
      "matchManagers": ["nix"],
      "groupName": "flake inputs",
      "schedule": ["every weekend"]
    },
    {
      "description": "Upstream bumps need src + npmDepsHash rehash by hand (see README)",
      "matchDepNames": ["gramps-project/gramps-web", "gramps-project/gramps-web-api"],
      "automerge": false,
      "schedule": ["at any time"]
    }
  ]
}
